# =====================================================
# AssemblyOps Backend Environment Variables
# =====================================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to version control

# =====================================================
# Database Configuration
# =====================================================
# Postgres connection. On Neon, use the two distinct endpoints:
#   DATABASE_URL -> POOLED endpoint (host contains "-pooler"), used at runtime
#   DIRECT_URL   -> DIRECT endpoint (no "-pooler"), used for Prisma migrations
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.us-east-1.aws.neon.tech/dbname?sslmode=require

# Direct (non-pooled) URL for Prisma migrations
DIRECT_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# Enable SSL for managed Postgres. Neon requires SSL → true.
# Local Postgres → false.
DATABASE_SSL=false

# =====================================================
# JWT Authentication
# =====================================================
# Secret key for signing JWT access tokens (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-very-secure-jwt-secret-key-at-least-32-characters-long

# Secret key for signing JWT refresh tokens (min 32 characters, must be different from JWT_SECRET)
# Generate with: openssl rand -base64 32
JWT_REFRESH_SECRET=your-very-secure-refresh-secret-key-at-least-32-characters-long

# =====================================================
# Volunteer Authentication
# =====================================================
# Secret key for encrypting volunteer credentials/tokens (32 bytes hex)
# Generate with: openssl rand -hex 32
VOLUNTEER_TOKEN_KEY=your-64-character-hex-key-for-volunteer-token-encryption

# =====================================================
# PII Encryption
# =====================================================
# Secret key for encrypting personally identifiable information (32 bytes hex)
# Generate with: openssl rand -hex 32
PII_ENCRYPTION_KEY=your-64-character-hex-key-for-encrypting-personal-data

# =====================================================
# OAuth Configuration (Optional)
# =====================================================
# Google OAuth 2.0 Client ID (for Sign in with Google)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Apple OAuth Client ID (for Sign in with Apple)
# Get from: https://developer.apple.com/account/resources/identifiers/list/serviceId
APPLE_CLIENT_ID=com.yourapp.services

# =====================================================
# Server Configuration
# =====================================================
# Port for the server to listen on
PORT=4000

# Node environment (development, production, test)
NODE_ENV=development

# =====================================================
# CORS Configuration
# =====================================================
# Comma-separated list of allowed origins for CORS
# Default allows localhost for development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# =====================================================
# GCP Configuration
# =====================================================
# Floor plan storage (Google Cloud Storage)
GCS_BUCKET=assemblyops-floor-plans

# GCP project and Cloud Run service (for admin monitoring)
GCP_PROJECT_ID=assemblyops-prod
GCP_REGION=us-east1
GCP_CLOUD_RUN_SERVICE=assemblyops-api

# Billing export (optional — for cost breakdown in admin portal)
# GCP_BILLING_DATASET=billing_dataset
# GCP_BILLING_TABLE=gcp_billing_export_v1_X
