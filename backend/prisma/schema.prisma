enum DepartmentType {
    ACCOUNTS
    ATTENDANT
    AUDIO
    BAPTISM
    CLEANING
    FIRST_AID
    INFORMATION_VOLUNTEER_SERVICE
    INSTALLATION
    LOST_FOUND_CHECKROOM
