// ─────────────────────────────────────────────
// AV DEPARTMENT — EQUIPMENT & SAFETY
// ─────────────────────────────────────────────

enum AVEquipmentCategory {
    CAMERA_PTZ
    CAMERA_MANNED
    TRIPOD
    AUDIO_MIXER
    VIDEO_SWITCHER
    MEDIA_PLAYER
    LED_PANEL
    LOUDSPEAKER
    MICROPHONE
    STAGE_MONITOR
    INTERCOM
    CABLE
    STAGE_LIGHTING
    RECORDING_DEVICE
    ASSISTIVE_LISTENING
    ACCESSORY
}

enum AVEquipmentCondition {
    GOOD
    NEEDS_REPAIR
    OUT_OF_SERVICE
}

enum AVDamageSeverity {
    MINOR
    MODERATE
    SEVERE
}

enum AVHazardType {
    WORKING_AT_HEIGHT
    ELECTRICAL_EXPOSURE
    ELEVATED_PLATFORM
    POWER_TOOLS
    MOVING_EQUIPMENT
    NEAR_STAIRS
    UNEVEN_SURFACE
    HEAVY_LIFTING
    PINCH_CRUSH_CUT
    EXTREME_CONDITIONS
}

model AVEquipmentItem {
    id           String               @id @default(cuid())
    name         String
    model        String?
    serialNumber String?
    category     AVEquipmentCategory
    condition    AVEquipmentCondition @default(GOOD)
    location     String?
    notes        String?
    areaId       String?
    eventId      String
    createdAt    DateTime             @default(now())
    updatedAt    DateTime             @updatedAt

    area          Area?                 @relation(fields: [areaId], references: [id])
    event         Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
    checkouts     AVEquipmentCheckout[]
    damageReports AVDamageReport[]

    @@index([eventId])
    @@index([areaId])
    @@index([category])
}

model AVEquipmentCheckout {
    id             String    @id @default(cuid())
    equipmentId    String
    checkedOutById String
    checkedOutAt   DateTime  @default(now())
    checkedInAt    DateTime?
    sessionId      String?
    notes          String?

    equipment    AVEquipmentItem @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
    checkedOutBy EventVolunteer  @relation(fields: [checkedOutById], references: [id], onDelete: Cascade)
    session      Session?        @relation(fields: [sessionId], references: [id])

    @@index([equipmentId])
    @@index([checkedOutById])
    @@index([checkedInAt])
}

model AVDamageReport {
    id              String           @id @default(cuid())
    equipmentId     String
    description     String
    severity        AVDamageSeverity
    reportedById    String
    sessionId       String?
    resolved        Boolean          @default(false)
    resolvedAt      DateTime?
    resolvedById    String?
    resolutionNotes String?
    createdAt       DateTime         @default(now())

    equipment  AVEquipmentItem @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
    reportedBy EventVolunteer  @relation(fields: [reportedById], references: [id], onDelete: Cascade)
    resolvedBy User?           @relation("ResolvedDamageReports", fields: [resolvedById], references: [id], onDelete: SetNull)
    session    Session?        @relation(fields: [sessionId], references: [id])

    @@index([equipmentId])
    @@index([resolved])
}

model AVHazardAssessment {
    id            String       @id @default(cuid())
    eventId       String
    title         String
    hazardType    AVHazardType
    description   String
    controls      String
    ppeRequired   String[]
    completedById String?
    sessionId     String?
    completedAt   DateTime     @default(now())

    event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
    completedBy User?    @relation(fields: [completedById], references: [id], onDelete: SetNull)
    session     Session? @relation(fields: [sessionId], references: [id])

    @@index([eventId])
}

model AVSafetyBriefing {
    id            String   @id @default(cuid())
    eventId       String
    topic         String
    notes         String?
    conductedById String?
    conductedAt   DateTime @default(now())

    event       Event                      @relation(fields: [eventId], references: [id], onDelete: Cascade)
    conductedBy User?                      @relation(fields: [conductedById], references: [id], onDelete: SetNull)
    attendees   AVSafetyBriefingAttendee[]

    @@index([eventId])
}

// ─────────────────────────────────────────────
// REMINDER CONFIRMATION
// ─────────────────────────────────────────────
// Tracks when a volunteer confirms they've read shift reminders (CO-23).
// Uses shiftId for shift-level confirmations, sessionId as fallback for non-shift depts.

model ReminderConfirmation {
    id               String   @id @default(cuid())
    eventVolunteerId String
    shiftId          String?
    sessionId        String?
    confirmedAt      DateTime @default(now())

    eventVolunteer EventVolunteer @relation(fields: [eventVolunteerId], references: [id], onDelete: Cascade)
    shift          Shift?         @relation(fields: [shiftId], references: [id], onDelete: Cascade)
    session        Session?       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

    @@unique([eventVolunteerId, shiftId])
    @@unique([eventVolunteerId, sessionId])
    @@index([eventVolunteerId])
}

model LanyardCheckout {
    id               String    @id @default(cuid())
    eventVolunteerId String
    eventId          String
    date             DateTime  @db.Date
    pickedUpAt       DateTime?
    returnedAt       DateTime?
    createdAt        DateTime  @default(now())
    updatedAt        DateTime  @updatedAt

    eventVolunteer EventVolunteer @relation(fields: [eventVolunteerId], references: [id], onDelete: Cascade)
    event          Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)

    @@unique([eventVolunteerId, date])
    @@index([eventId, date])
}

model AVSafetyBriefingAttendee {
    id               String   @id @default(cuid())
    briefingId       String
    eventVolunteerId String
    createdAt        DateTime @default(now())

    briefing       AVSafetyBriefing @relation(fields: [briefingId], references: [id], onDelete: Cascade)
    eventVolunteer EventVolunteer   @relation(fields: [eventVolunteerId], references: [id], onDelete: Cascade)

    @@unique([briefingId, eventVolunteerId])
}
